# === OpenAI / LLM Configuration ===
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o

# === Embedding Configuration ===
EMBEDDING_API_KEY=sk-your-embedding-api-key-here
EMBEDDING_MODEL_NAME=text-embedding-3-small

# === Anthropic ===
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# === Google Gemini ===
GOOGLE_API_KEY=your-google-api-key-here

# === OpenAI-Compatible Providers ===
# Uncomment and configure for non-OpenAI providers
# QWEN_API_KEY=your-qwen-api-key-here
# QWEN_BASE_URL=https://your-qwen-compatible-endpoint/v1
# DEEPSEEK_API_KEY=your-deepseek-api-key-here
# DEEPSEEK_BASE_URL=https://your-deepseek-compatible-endpoint/v1

# === Project Paths ===
PROJECT_ROOT=/path/to/SoccerRef-Agents
DB_PATH=./referee_vector_db

# === Multi-Agent System ===
DATASET_PATH=Database/Text/text.json
OUTPUT_FILE=output.json

# === Baseline Evaluation ===
BASELINE_MODEL=gpt-4o
VIDEO_DATASET_ROOT=Dataset/video_dataset
DEFAULT_DATASET_PATH=Dataset/video_dataset/your_dataset_file.json
DEFAULT_OUTPUT_PATH=Results/model_performance_summary.json
SUMMARY_FILE_PATH=model_performance_summary.json

# === Knowledge Base (for vector DB indexing) ===
KNOWLEDGE_BASE_PDF_PATH=KnowledgeBase/Laws of the Game 2025_26_single pages.pdf
KNOWLEDGE_BASE_CASES_PATH=KnowledgeBase/classic_case_knowledge.json

# === SoccerNet Data Download ===
SOCCERNET_PASSWORD=your-soccernet-password-here
